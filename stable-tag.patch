+/// Ensures `codex-litellm` works with only LiteLLM endpoint/key in
+/// `~/.codex/.env`, without requiring a separate CODEX_HOME or provider block
+/// in `config.toml`.
+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn responses_mode_stream_codex_litellm_uses_default_home_dotenv_for_litellm_provider() {
+    skip_if_no_network!();
+
+    let server = MockServer::start().await;
+    let repo_root = repo_root();
+    let sse = responses::sse(vec![
+        responses::ev_response_created("resp-1"),
+        responses::ev_assistant_message("msg-1", "hi"),
+        responses::ev_completed("resp-1"),
+    ]);
+    let resp_mock = responses::mount_sse_once(&server, sse).await;
+
+    let home_root = TempDir::new().unwrap();
+    let codex_home = home_root.path().join(".codex");
+    std::fs::create_dir_all(&codex_home).unwrap();
+    std::fs::write(
+        codex_home.join(".env"),
+        format!(
+            concat!("LITELLM_BASE_URL={}/v1\n", "LITELLM_API_KEY=dummy-key\n",),
+            server.uri()
+        ),
+    )
+    .unwrap();
+
+    let bin = codex_utils_cargo_bin::cargo_bin("codex-litellm").unwrap();
+    let mut cmd = AssertCommand::new(bin);
+    cmd.timeout(Duration::from_secs(30));
+    cmd.arg("exec")
+        .arg("--skip-git-repo-check")
+        .arg("--model")
+        .arg("vercel/minimax-m2.5")
+        .arg("-C")
+        .arg(&repo_root)
+        .arg("hello?");

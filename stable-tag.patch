+) -> bool {
+    if is_cross_provider_model_alias(previous_model, current_model) {
+        return false;
+    }
+
+    if let Some(previous_provider) = previous_provider
+        && previous_provider != current_provider
+    {
+        return false;
+    }
+
+    true
+}

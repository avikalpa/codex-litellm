+        .arg(test.cwd_path())
+        .arg(&prompt)
+        .assert()
+        .success();
+
+    let sessions_dir = test.home_path().join("sessions");
+    let path = find_session_file_containing_marker(&sessions_dir, &marker)
+        .expect("no session file found after first run");
+
+    let marker2 = format!("resume-cross-provider-2-{}", Uuid::new_v4());
+    let prompt2 = format!("echo {marker2}");
+
+    let output = test
+        .cmd()
+        .env("CODEX_RS_SSE_FIXTURE", &fixture)
+        .env("OPENAI_BASE_URL", "http://unused.local")
+        .arg("--profile")
+        .arg("codex-litellm")
+        .arg("--skip-git-repo-check")
+        .arg("-C")
+        .arg(test.cwd_path())
+        .arg(&prompt2)
+        .arg("resume")
+        .arg("--last")
+        .arg("--all")
+        .output()
+        .context("cross-provider resume run should succeed")?;
+
+    assert!(
+        output.status.success(),
+        "cross-provider resume run failed: {output:?}"
+    );
+
+    let stderr = String::from_utf8(output.stderr)?;
+    assert!(
+        stderr.contains("provider: litellm"),
+        "stderr missing litellm provider summary: {stderr}"
+    );
+    assert!(
+        stderr.contains("model: vercel/minimax-m2.7-highspeed"),
+        "stderr missing litellm model summary: {stderr}"
+    );
+    assert!(
+        !stderr.contains("Consider switching back to `gpt-5.4`"),
+        "unexpected cross-provider alias warning: {stderr}"
+    );
+
+    let resumed_path = find_session_file_containing_marker(&sessions_dir, &marker2)
+        .expect("no resumed session file containing marker2");
+    assert_eq!(
+        resumed_path, path,
+        "cross-provider resume should append to the existing file"
+    );
+
+    let content = std::fs::read_to_string(&resumed_path)?;

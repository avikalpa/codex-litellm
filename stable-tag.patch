+        ));
+        config_overrides.raw_overrides.push(format!(
+            "model_providers.litellm.base_url={}",
+            toml::Value::String(base_url.to_string())
+        ));
+        config_overrides.raw_overrides.push(format!(
+            "model_providers.litellm.env_key={}",
+            toml::Value::String("LITELLM_API_KEY".to_string())
+        ));
+        config_overrides.raw_overrides.push(format!(
+            "model_providers.litellm.wire_api={}",
+            toml::Value::String("responses".to_string())
+        ));
+    }
+    if let Some(api_key) = api_key {
+        config_overrides.raw_overrides.push(format!(
+            "model_providers.litellm.experimental_bearer_token={}",
+            toml::Value::String(api_key.to_string())
+        ));
+    }
+    if let Some(default_model) = default_model {
+        config_overrides.raw_overrides.push(format!(
+            "profiles.{CODEX_LITELLM_PROFILE_NAME}.model={}",
+            toml::Value::String(default_model.to_string())
+        ));
+    }
+}
+
+fn upsert_dotenv_entry(path: &Path, key: &str, value: &str) -> anyhow::Result<()> {
+    let existing = match fs::read_to_string(path) {
+        Ok(contents) => contents,
+        Err(err) if err.kind() == std::io::ErrorKind::NotFound => String::new(),
+        Err(err) => return Err(err.into()),
+    };
+    let mut found = false;
+    let mut lines = Vec::new();
+    for line in existing.lines() {
+        if dotenv_entry_key(line) == Some(key) {
+            lines.push(format!("{key}={}", encode_dotenv_value(value)));
+            found = true;
+        } else {
+            lines.push(line.to_string());
+        }
+    }
+    if !found {
+        lines.push(format!("{key}={}", encode_dotenv_value(value)));
+    }
+    let mut updated = lines.join("\n");
+    if !updated.is_empty() {
+        updated.push('\n');
+    }
+    fs::write(path, updated)?;
+    Ok(())
+}
+
+fn encode_dotenv_value(value: &str) -> String {
+    serde_json::to_string(value).unwrap_or_else(|_| format!("\"{}\"", value.replace('"', "\\\"")))
+}
+
+fn dotenv_entry_key(line: &str) -> Option<&str> {
+    let trimmed = line.trim_start();
+    if trimmed.is_empty() || trimmed.starts_with('#') {
+        return None;
+    }
+    let (key, _) = trimmed.split_once('=')?;
+    let key = key.trim();
+    if key.is_empty() {
+        None
+    } else {
+        Some(key)
+    }
+}
+
+fn prompt_required(prompt: &str) -> anyhow::Result<String> {
+    loop {
+        let value = prompt_optional(prompt)?;
+        if let Some(value) = value {
+            return Ok(value);
+        }
+        eprintln!("A value is required.");
+    }
+}
+
+fn prompt_optional(prompt: &str) -> anyhow::Result<Option<String>> {
+    eprint!("{prompt}");
+    std::io::stderr().flush()?;
+    let mut input = String::new();
+    std::io::stdin().read_line(&mut input)?;
+    let trimmed = input.trim();
+    if trimmed.is_empty() {
+        Ok(None)
+    } else {
+        Ok(Some(trimmed.to_string()))
+    }
+}

+use codex_protocol::openai_models::ModelPreset;
+
+const AGENTIC_SUPPORTED_MODELS: &[&str] = &[
+    "gpt-5.4",
+    "gpt-5.4-pro",
+    "gpt-5.3-codex",
+    "claude-sonnet-4.6",
+    "claude-opus-4.6",
+    "gemini-3.1-pro-preview",
+    "gemini-3-pro",
+    "gemini-3-flash",
+    "grok-4.1-fast-reasoning",
+    "grok-4.20-reasoning-beta",
+    "claude-haiku-4.5",
+    "glm-5",
+    "glm-5-turbo",
+    "deepseek-v3.2-thinking",
+    "kimi-k2.5",
+    "minimax-m2.5",
+    "minimax-m2.7",
+    "minimax-m2.7-highspeed",
+];
+
+fn normalize_model_token(model: &str) -> String {
+    model.replace('.', "-")
+}
+
+fn model_candidates(model: &str) -> impl Iterator<Item = &str> {
+    std::iter::once(model)
+        .chain(model.rsplit('/').next())
+        .chain(model.rsplit(':').next())
+}
+
+pub(crate) fn is_supported_agentic_model(model: &str) -> bool {
+    let normalized_candidates = model_candidates(model)
+        .map(normalize_model_token)
+        .collect::<Vec<_>>();
+
+    AGENTIC_SUPPORTED_MODELS.iter().any(|candidate| {
+        let normalized_candidate = normalize_model_token(candidate);
+        normalized_candidates.iter().any(|value| {
+            value == candidate
+                || value == &normalized_candidate
+                || value
+                    .strip_prefix(&normalized_candidate)
+                    .is_some_and(|suffix| suffix.starts_with('-'))
+        })
+    })
+}
+
+pub(crate) fn filter_supported_agentic_models(models: Vec<ModelPreset>) -> Vec<ModelPreset> {
+    models
+        .into_iter()
+        .filter(|preset| is_supported_agentic_model(&preset.model))
+        .collect()
+}
+
+pub(crate) fn supported_agentic_models() -> &'static [&'static str] {
+    AGENTIC_SUPPORTED_MODELS
+}

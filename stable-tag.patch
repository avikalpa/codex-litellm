+                required: Some(vec!["command".to_string()]),
+                additional_properties: Some(false.into()),
+            },
+        )),
+        ToolSpec::Freeform(tool) => Some(normalize_freeform_tool_spec_for_litellm(tool)),
+        ToolSpec::WebSearch { .. } | ToolSpec::ImageGeneration { .. } => None,
+    }
+}
+
+fn normalize_freeform_tool_spec_for_litellm(tool: &FreeformTool) -> ToolSpec {
+    function_tool_spec(
+        tool.name.clone(),
+        format!(
+            "{} Pass the raw tool input string as the JSON field `input`.",
+            tool.description
+        ),
+        JsonSchema::Object {
+            properties: std::collections::BTreeMap::from([(
+                "input".to_string(),
+                JsonSchema::String {
+                    description: Some("Raw input string for this tool.".to_string()),
+                },
+            )]),
+            required: Some(vec!["input".to_string()]),
+            additional_properties: Some(false.into()),
+        },
+    )
+}
+
+fn function_tool_spec(
+    name: impl Into<String>,
+    description: String,
+    parameters: JsonSchema,
+) -> ToolSpec {
+    ToolSpec::Function(ResponsesApiTool {
+        name: name.into(),
+        description,
+        strict: false,
+        defer_loading: None,
+        parameters,
+        output_schema: None,
+    })
+}

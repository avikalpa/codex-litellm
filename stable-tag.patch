+        let mut config_overrides = CliConfigOverrides::default();
+
+        apply_codex_litellm_defaults(Some("codex-litellm"), &mut config_overrides);
+
+        assert_eq!(
+            config_overrides.raw_overrides,
+            vec![
+                format!("profile=\"{CODEX_LITELLM_PROFILE_NAME}\""),
+                format!("profiles.{CODEX_LITELLM_PROFILE_NAME}.model_provider=\"litellm\""),
+            ]
+        );
+    }
+
+    #[test]
+    fn codex_litellm_defaults_respect_explicit_profile_and_provider_override() {
+        let mut config_overrides = CliConfigOverrides {
+            raw_overrides: vec![
+                "profile=\"team\"".to_string(),
+                format!("profiles.{CODEX_LITELLM_PROFILE_NAME}.model_provider=\"custom\""),
+            ],
+        };
+
+        apply_codex_litellm_defaults(Some("codex-litellm.exe"), &mut config_overrides);
+
+        assert_eq!(
+            config_overrides.raw_overrides,
+            vec![
+                "profile=\"team\"".to_string(),
+                format!("profiles.{CODEX_LITELLM_PROFILE_NAME}.model_provider=\"custom\""),
+            ]
+        );

+impl UnifiedExecHandler {
+    async fn should_block_post_edit_read_only_command(
+        command: &[String],
+        tracker: &crate::tools::context::SharedTurnDiffTracker,
+    ) -> bool {
+        if !is_known_safe_command(command) || is_allowed_post_edit_read_only_command(command) {
+            return false;
+        }
+
+        let mut tracker = tracker.lock().await;
+        tracker.saw_successful_mutating_shell_command()
+            || tracker.get_unified_diff().ok().flatten().is_some()
+    }
+
+    fn shell_command_contains_output_redirection(command: &[String]) -> bool {
+        let Some(shell) = command.first().map(|value| value.as_str()) else {
+            return false;
+        };
+        let Some(script) = command.last().map(|value| value.as_str()) else {
+            return false;
+        };
+
+        let shell_name = std::path::Path::new(shell)
+            .file_name()
+            .and_then(|value| value.to_str())
+            .unwrap_or(shell);
+        let is_shell_wrapper = matches!(shell_name, "bash" | "sh" | "zsh")
+            && command
+                .iter()
+                .skip(1)
+                .any(|arg| arg == "-c" || arg == "-lc");
+
+        is_shell_wrapper
+            && (script.contains(">>")
+                || script.contains(" >")
+                || script.contains("1>")
+                || script.contains("2>")
+                || script.contains("&>"))
+    }
+}

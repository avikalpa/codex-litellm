+pub(crate) fn remove_duplicate_call_entries(items: &mut Vec<ResponseItem>) {
+    let mut seen_function_call_ids = HashSet::new();
+    let mut seen_tool_search_call_ids = HashSet::new();
+    let mut seen_local_shell_call_ids = HashSet::new();
+    let mut seen_custom_tool_call_ids = HashSet::new();
+
+    items.retain(|item| match item {
+        ResponseItem::FunctionCall { call_id, .. } => {
+            seen_function_call_ids.insert(call_id.clone())
+        }
+        ResponseItem::ToolSearchCall {
+            call_id: Some(call_id),
+            ..
+        } => seen_tool_search_call_ids.insert(call_id.clone()),
+        ResponseItem::LocalShellCall {
+            call_id: Some(call_id),
+            ..
+        } => seen_local_shell_call_ids.insert(call_id.clone()),
+        ResponseItem::CustomToolCall { call_id, .. } => {
+            seen_custom_tool_call_ids.insert(call_id.clone())
+        }
+        _ => true,
+    });

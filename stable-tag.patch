+fn is_cross_provider_model_alias(previous: &str, current: &str) -> bool {
+    if previous == current {
+        return true;
+    }
+
+    let previous_suffix = previous.rsplit('/').next().unwrap_or(previous);
+    let current_suffix = current.rsplit('/').next().unwrap_or(current);
+
+    previous_suffix == current_suffix && (previous.contains('/') != current.contains('/'))
+}
+
+fn previous_session_provider_from_rollout_items(items: &[RolloutItem]) -> Option<&str> {
+    items.iter().find_map(|item| match item {
+        RolloutItem::SessionMeta(meta_line) => meta_line.meta.model_provider.as_deref(),
+        RolloutItem::ResponseItem(_)
+        | RolloutItem::Compacted(_)
+        | RolloutItem::TurnContext(_)
+        | RolloutItem::EventMsg(_) => None,
+    })
+}

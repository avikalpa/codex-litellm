+fn is_codex_litellm_invocation(invocation_name: Option<&str>) -> bool {
+    let Some(invocation_name) = invocation_name else {
+        return false;
+    };
+    let stem = invocation_name
+        .strip_suffix(".exe")
+        .unwrap_or(invocation_name)
+        .to_ascii_lowercase();
+    stem == "codex-litellm"
+}
